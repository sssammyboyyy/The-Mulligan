        {
            "parameters": {
                "jsCode": "var booking = $('Validate & Prep').item.json;\n\n// Intelligent Add-on Detection\nvar addonList = [];\nif (booking.addon_coaching) addonList.push('<li style=\"color: #059669; font-weight: bold;\">\ud83c\udfcc\ufe0f PRO COACHING BOOKED</li>');\nif (booking.addon_club_rental) addonList.push('<li style=\"color: #059669; font-weight: bold;\">\ud83c\udfcc\ufe0f CLUB RENTAL BOOKED</li>');\nvar addonsHtml = addonList.length > 0 ? `<ul style=\"margin: 10px 0; padding-left: 20px;\">${addonList.join('')}</ul>` : '<p style=\"color: #9ca3af; font-style: italic;\">No add-ons selected</p>';\n\n// Premium Alert Template\nvar html = `\n<div style=\"font-family: sans-serif; max-width: 500px; margin: 0 auto; border: 2px solid #dc2626; border-radius: 12px; overflow: hidden;\">\n    <div style=\"background: #dc2626; color: white; padding: 15px; text-align: center;\">\n        <h2 style=\"margin: 0; font-size: 20px;\">\u26a0\ufe0f NEW BOOKING ALERT</h2>\n    </div>\n    <div style=\"padding: 20px; background: #fff;\">\n        <div style=\"margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #f3f4f6;\">\n            <p style=\"margin: 0 0 5px; color: #6b7280; font-size: 12px; font-weight: bold; text-transform: uppercase;\">Guest Details</p>\n            <p style=\"margin: 0; font-size: 18px; font-weight: bold; color: #111827;\">${booking.guest_name}</p>\n            <p style=\"margin: 5px 0 0; color: #4b5563;\">${booking.guest_phone || 'No phone'}</p>\n        </div>\n\n        <div style=\"margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #f3f4f6;\">\n            <p style=\"margin: 0 0 5px; color: #6b7280; font-size: 12px; font-weight: bold; text-transform: uppercase;\">Slot & Bay</p>\n            <p style=\"margin: 0; font-size: 16px; color: #111827;\">\ud83d\udcc5 <strong>${booking.booking_date}</strong> | \ud83d\udd50 <strong>${booking.start_time}</strong></p>\n            <p style=\"margin: 5px 0 0; color: #111827;\">\ud83d\udccd ${booking.bay_name}</p>\n        </div>\n\n        <div style=\"margin-bottom: 20px; background: #fef2f2; padding: 15px; border-radius: 8px; border: 1px solid #fee2e2;\">\n            <p style=\"margin: 0 0 8px; color: #991b1b; font-size: 12px; font-weight: bold; text-transform: uppercase;\">\ud83d\udce6 ADD-ONS & SERVICES</p>\n            ${addonsHtml}\n        </div>\n\n        <div style=\"background: #f9fafb; padding: 15px; border-radius: 8px;\">\n            <table style=\"width: 100%; border-collapse: collapse;\">\n                <tr><td style=\"color: #6b7280; padding: 4px 0;\">Total Price</td><td style=\"text-align: right; font-weight: bold;\">R${booking.total_price}</td></tr>\n                <tr><td style=\"color: #6b7280; padding: 4px 0;\">Amt Paid</td><td style=\"text-align: right; color: #059669; font-weight: bold;\">R${booking.amount_paid}</td></tr>\n                <tr style=\"border-top: 1px solid #e5e7eb;\"><td style=\"padding: 8px 0; font-weight: bold;\">Balance Due</td><td style=\"text-align: right; padding: 8px 0; font-weight: bold; color: #dc2626; font-size: 18px;\">R${booking.amount_due}</td></tr>\n            </table>\n            <p style=\"margin: 10px 0 0; font-size: 12px; color: #6b7280; text-align: center;\">Status: ${booking.paymentStatus.toUpperCase()}</p>\n        </div>\n    </div>\n</div>`;\n\nreturn { json: { from: \"Mulligan Notifications <alerts@themulligan.org>\", to: [\"themulligan.store@gmail.com\"], subject: \"\ud83d\udcc5 NEW: \" + booking.guest_name + \" (\" + booking.bay_name + \")\", html: html } };"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1600,
                300
            ],
            "id": "prepare-store-email",
            "name": "Prepare Store Email"
        },
