;\"><tr><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;text-align:left;\">Date</td><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827;font-weight:600;text-align:right;\">{{ $('Validate & Prep1').item.json.booking_date }}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;text-align:left;\">Start Time</td><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827;font-weight:600;text-align:right;\">{{ $('Validate & Prep1').item.json.start_time }}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;text-align:left;\">Duration</td><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827;font-weight:600;text-align:right;\">{{ $('Validate & Prep1').item.json.duration_hours || 1 }} Hours</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;text-align:left;\">Bay Location</td><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827;font-weight:600;text-align:right;\">{{ {1: 'Lounge Bay', 2: 'Middle Bay', 3: 'Window Bay'}[$('Validate & Prep1').item.json.simulator_id] || 'Bay ' + $('Validate & Prep1').item.json.simulator_id }}</td></tr><tr><td style=\"padding:12px 0;font-size:14px;color:#6b7280;text-align:left;\">Players</td><td style=\"padding:12px 0;font-size:14px;color:#111827;font-weight:600;text-align:right;\">{{ $('Validate & Prep1').item.json.player_count || 1 }} Players</td></tr></table></div><div style=\"background-color:#ecfdf5;border:1px solid #d1fae5;border-radius:12px;padding:24px;margin-bottom:32px;text-align:center;\"><span style=\"font-size:13px;color:#065f46;opacity:0.7;margin-bottom:12px;display:block;font-weight:500;\">SECURED VIA DEPOSIT</span><p style=\"font-size:28px;font-weight:700;color:#065f46;margin:0;\">R{{ $('Validate & Prep1').item.json.depositPaid }} Paid</p><div style=\"margin-top:16px;padding-top:16px;border-top:1px solid rgba(6,95,70,0.1);display:flex;justify-content:center;align-items:center;gap:8px;\"><span style=\"font-size:14px;color:#065f46;font-weight:500;\">Balance Due at Venue:</span><span style=\"font-size:18px;font-weight:700;color:#92400e;\">R{{ $('Validate & Prep1').item.json.outstandingBalance }}</span></div></div><div style=\"margin-bottom:32px;\"><h3 style=\"font-size:16px;font-weight:700;color:#1a472a;margin:0 0 16px;\">Session Prep</h3><div style=\"margin-bottom:12px;font-size:14px;color:#4b5563;line-height:1.5;\"><span style=\"color:#059669;font-weight:bold;margin-right:10px;\">✓</span><strong>Arrive 10 mins early</strong> — Grab a coffee and settle in before tee-off.</div><div style=\"margin-bottom:12px;font-size:14px;color:#4b5563;line-height:1.5;\"><span style=\"color:#059669;font-weight:bold;margin-right:10px;\">✓</span><strong>The Gear</strong> — Club rentals are available at R100/hr, or bring your own free of charge.</div><div style=\"margin-bottom:12px;font-size:14px;color:#4b5563;line-height:1.5;\"><span style=\"color:#059669;font-weight:bold;margin-right:10px;\">✓</span><strong>Clean Play</strong> — Ensure your gear is clean; sharpie marks damage our screens.</div></div><div style=\"text-align:center;margin-top:40px;\"><a href=\"https://maps.google.com/?q=38A+Chopin+St+Vanderbijlpark\" style=\"display:inline-block;background-color:#1a472a;color:#ffffff;padding:18px 36px;border-radius:12px;text-decoration:none;font-weight:700;font-size:16px;box-shadow:0 4px 12px rgba(26,71,42,0.2);\">Get Directions</a></div></div><div style=\"background-color:#f9fafb;padding:40px;text-align:center;border-top:1px solid #f3f4f6;\"><div style=\"color:#1a472a;font-size:18px;font-weight:800;margin-bottom:12px;\">The Mulligan</div><div style=\"font-size:13px;color:#9ca3af;margin-bottom:24px;line-height:1.5;\">38A Chopin St, Vanderbijlpark S.W. 5<br>Gauteng, South Africa</div><div style=\"fo