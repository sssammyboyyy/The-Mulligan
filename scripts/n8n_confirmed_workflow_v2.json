        },
        {
            "parameters": {
                "jsCode": "const booking = $input.first().json;\n\nconst html = `\n<div style=\"font-family:'Helvetica Neue',Arial,sans-serif;max-width:600px;margin:0 auto;color:#1f2937;line-height:1.5;\">\n  <div style=\"background-color:#1a472a;background-image:linear-gradient(135deg,#1a472a 0%,#0d2a19 100%);padding:60px 40px;text-align:center;border-radius:12px 12px 0 0;\">\n    <div style=\"display:inline-block;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;padding:6px 16px;border-radius:100px;font-size:12px;font-weight:600;margin-bottom:20px;\">SESSION CONFIRMED</div>\n    <p style=\"color:#fff;font-size:24px;font-weight:800;letter-spacing:-0.5px;margin:0 0 8px;\">The Mulligan</p>\n    <p style=\"color:#fbbf24;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin:0 0 30px;opacity:0.9;\">The Simulator Never Judges</p>\n    <h1 style=\"color:#fff;font-size:32px;font-weight:700;margin:0;line-height:1.2;\">You're Teeing Off!</h1>\n    <p style=\"color:#a3d9a5;font-size:16px;margin:12px 0 0;opacity:0.8;\">See you on the green, ${booking.guest_name}.</p>\n  </div>\n  <div style=\"padding:40px;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 12px 12px;background-color:#ffffff;\">\n    <p style=\"font-size:18px;color:#111827;font-weight:600;margin:0 0 16px;\">Exciting news, ${booking.guest_name}!</p>\n    <p style=\"font-size:15px;color:#4b5563;line-height:1.6;margin:0 0 32px;\">Your booking at The Mulligan is confirmed. We've reserved Bay ${booking.simulator_id} exclusively for your group.</p>\n    <div style=\"background-color:#f9fafb;border:1px solid #f3f4f6;border-radius:12px;padding:24px;margin-bottom:32px;\">\n      <span style=\"font-size:12px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:1px;margin-bottom:20px;display:block;\">BOOKING DETAILS</span>\n      <table style=\"width:100%;border-collapse:collapse;\">\n        <tr><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;\">Date</td><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827;font-weight:600;text-align:right;\">${booking.booking_date}</td></tr>\n        <tr><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;\">Start Time</td><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827;font-weight:600;text-align:right;\">${booking.start_time}</td></tr>\n        <tr><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;\">Duration</td><td style=\"padding:12px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827;font-weight:600;text-align:right;\">${booking.duration_hours} Hours</td></tr>\n        <tr><td style=\"padding:12px 0;font-size:14px;color:#6b7280;\">Players</td><td style=\"padding:12px 0;font-size:14px;color:#111827;font-weight:600;text-align:right;\">${booking.player_count || '-'} Players</td></tr>\n      </table>\n    </div>\n    <div style=\"background-color:#ecfdf5;border:1px solid #d1fae5;border-radius:12px;padding:24px;margin-bottom:32px;text-align:center;\">\n      <span style=\"font-size:13px;color:#065f46;opacity:0.7;margin-bottom:12px;display:block;font-weight:500;\">PAYMENT RECEIVED</span>\n      <p style=\"font-size:28px;font-weight:700;color:#065f46;margin:0;\">R${booking.amount_paid} Paid</p>\n      <div style=\"margin-top:16px;padding-top:16px;border-top:1px solid rgba(6,95,70,0.1);\">\n        <span style=\"font-size:14px;color:#065f46;font-weight:500;\">Balance Due at Venue: </span>\n        <span style=\"font-size:18px;font-weight:700;color:#92400e;\">R${(Number(booking.total_price) - Number(booking.amount_paid)).toFixed(0)}</span>\n      </div>\n    </div>\n    ${booking.addon_coaching ? '<div style=\"background:#fffbeb;border:1px solid #f59e0b;border-radius:8px;padding:12px 16px;margin-bottom:12px;font-size:14px;color:#92400e;\">✓ <strong>Pro Coaching</strong> included</div>' : ''}\n    ${booking.addon_club_rental ? '<div style=\"background:#fffbeb;border:1px solid #f59e0b;border-radius:8px;padding:12px 16px;margin-bottom:12px;font-size:14px;color:#92400e;\">✓ <strong>Club Rental</strong> included</div>' : ''}\n    <div style=\"margin-bottom:32px;\">\n      <h3 style=\"font-size:16px;font-weight:700;color:#1a472a;margin:0 0 16px;\">Session Prep</h3>\n      <div style=\"margin-bottom:12px;font-size:14px;color:#4b5563;line-height:1.5;\"><span style=\"color:#059669;font-weight:bold;margin-right:10px;\">✓</span><strong>Arrive 10 mins early</strong> — Grab a coffee and settle in.</div>\n      <div style=\"margin-bottom:12px;font-size:14px;color:#4b5563;line-height:1.5;\"><span style=\"color:#059669;font-weight:bold;margin-right:10px;\">✓</span><strong>The Gear</strong> — Club rentals available, or bring your own.</div>\n      <div style=\"margin-bottom:12px;font-size:14px;color:#4b5563;line-height:1.5;\"><span style=\"color:#059669;font-weight:bold;margin-right:10px;\">✓</span><strong>Clean Play</strong> — No sharpie-marked balls; they damage our screens.</div>\n    </div>\n    <div style=\"text-align:center;margin-top:40px;\"><a href=\\\"https://maps.google.com/?q=38A+Chopin+St+Vanderbijlpark\\\" style=\"display:inline-block;background-color:#1a472a;color:#ffffff;padding:18px 36px;border-radius:12px;text-decoration:none;font-weight:700;font-size:16px;box-shadow:0 4px 12px rgba(26,71,42,0.2);\">Get Directions</a></div>\n  </div>\n  <div style=\"background-color:#f9fafb;padding:40px;text-align:center;border-top:1px solid #f3f4f6;\">\n    <div style=\"color:#1a472a;font-size:18px;font-weight:800;margin-bottom:12px;\">The Mulligan</div>\n    <div style=\"font-size:13px;color:#9ca3af;margin-bottom:24px;line-height:1.5;\">38A Chopin St, Vanderbijlpark S.W. 5<br>Gauteng, South Africa</div>\n    <div style=\"font-size:11px;color:#9ca3af;\">&copy; 2026 The Mulligan Golf Lounge. All rights reserved.</div>\n  </div>\n</div>`;\n\nreturn [\n  {\n    json: {\n      from: 'The Mulligan <bookings@themulligan.org>',\n      to: [booking.guest_email],\n      subject: 'Booking Confirmed – The Mulligan',\n      html: html\n    }\n  }\n];"
            },
