                "responseMode": "lastNode",
                "options": {}
            },
            "id": "b27af0e9-23e6-4e2d-9092-02f84317395d",
            "name": "Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                4928,
                3136
            ],
            "webhookId": "manual-confirm"
        },
        {
            "parameters": {
                "jsCode": "// This node validates the incoming webhook trigger and extracts the bookingId.\n\nconst input = items[0].json;\nconst data = input.body || input;\n\nconst ADMIN_SECRET = $env[\"N8N_ADMIN_SECRET\"];\nconst RECONCILE_SECRET = $env[\"N8N_RECONCILE_SECRET\"];\n\nif (!ADMIN_SECRET || !RECONCILE_SECRET) {\n  throw new Error('n8n environment variables N8N_ADMIN_SECRET or N8N_RECONCILE_SECRET are not set.');\n}\n\nconst bookingId = data.bookingId;\nconst receivedSecret = data.secret;\n\nif (!bookingId) {\n  throw new Error('CRITICAL: Webhook payload is missing bookingId.');\n}\n\nconst isValid = (receivedSecret === ADMIN_SECRET || receivedSecret === RECONCILE_SECRET);\n\nif (!isValid) {\n  // For security, we don't throw an error, just stop the workflow.\n  return { json: { valid: false, bookingId: bookingId } };\n}\n\n// Pass the validated bookingId to the next step.\nreturn { json: { valid: true, bookingId: bookingId } };"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                5120,
                3136
            ],
            "id": "validate-and-extract",
            "name": "Validate & Extract"
        },
        {
            "parameters": {
                "operation": "getAll",
                "tableId": "bookings",
                "limit": 1,
                "filters": {
                    "conditions": [
                        {
                            "keyName": "id",
                            "condition": "eq",
                            "keyValue": "={{ $('Validate & Extract').item.json.bookingId }}"
                        }
                    ]
                }
            },
            "id": "1d5a4852-3170-4746-853e-1265c6a35284",
            "name": "Get Booking",
