        {
            "parameters": {
                "jsCode": "const booking = $input.first().json;\n\nconst html = `\n<div style=\"font-family:'Helvetica Neue',Arial,sans-serif;max-width:600px;margin:0 auto;color:#1f2937;line-height:1.5;\">\n  <div style=\"background-color:#1a472a;padding:30px;text-align:center;border-radius:12px 12px 0 0;\">\n    <h1 style=\"color:#ffffff;margin:0;font-size:24px;letter-spacing:1px;\">BOOKING ALERT</h1>\n    <p style=\"color:#a3d9a5;margin:5px 0 0 0;font-size:12px;text-transform:uppercase;\">Store Operations Notification</p>\n  </div>\n  <div style=\"padding:30px;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 12px 12px;background-color:#ffffff;\">\n    <div style=\"margin-bottom:25px;\">\n      <h2 style=\"font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:1px;margin-bottom:15px;border-bottom:1px solid #f3f4f6;padding-bottom:5px;\">👤 Guest Details</h2>\n      <table style=\"width:100%;border-collapse:collapse;\">\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Name</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">${booking.guest_name}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Phone</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">${booking.guest_phone || '-'}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Email</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">${booking.guest_email}</td></tr>\n      </table>\n    </div>\n    <div style=\"background-color:#f9fafb;border-radius:8px;padding:20px;margin-bottom:25px;\">\n      <h2 style=\"font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:1px;margin-bottom:15px;border-bottom:1px solid #e5e7eb;padding-bottom:5px;\">🕒 Session Info</h2>\n      <table style=\"width:100%;border-collapse:collapse;\">\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Date</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">${booking.booking_date}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Time</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">${booking.start_time}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Duration</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">${booking.duration_hours} Hours</td></tr>\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Bay</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#1a472a;\">Bay ${booking.simulator_id}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Players</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">${booking.player_count || '-'} Players</td></tr>\n      </table>\n    </div>\n    <div style=\"border:2px solid #e5e7eb;border-radius:8px;padding:20px;\">\n      <h2 style=\"font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:1px;margin-bottom:15px;\">💰 Financial Summary</h2>\n      <table style=\"width:100%;border-collapse:collapse;\">\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Total Amount</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#111827;\">R${booking.total_price}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#6b7280;\">Paid Online</td><td style=\"padding:8px 0;text-align:right;font-weight:700;color:#15803d;\">R${booking.amount_paid}</td></tr>\n        <tr style=\"font-size:18px;\"><td style=\"padding:15px 0 0 0;border-top:2px solid #e5e7eb;font-weight:800;color:#111827;\">BALANCE DUE</td><td style=\"padding:15px 0 0 0;border-top:2px solid #e5e7eb;text-align:right;font-weight:800;color:#b45309;\">R${(Number(booking.total_price) - Number(booking.amount_paid)).toFixed(0)}</td></tr>\n      </table>\n    </div>\n    <div style=\"margin-top:30px;text-align:center;\"><a href=\\\"https://themulligan.org/admin\\\" style=\"display:inline-block;background-color:#1a472a;color:#ffffff;padding:15px 30px;border-radius:8px;text-decoration:none;font-weight:700;font-size:14px;box-shadow:0 4px 6px rgba(0,0,0,0.1);\">OPEN ADMIN DASHBOARD</a></div>\n    <p style=\"margin-top:25px;font-size:12px;color:#9ca3af;text-align:center;\">This is an automated operational notification.<br>The Mulligan Golf Lounge</p>\n  </div>\n</div>`;\n\nreturn [\n  {\n    json: {\n      from: 'The Mulligan <alerts@themulligan.org>',\n      to: ['themulligan.store@gmail.com'],\n      subject: `BOOKING ALERT: ${booking.guest_name}`,\n      html: html\n    }\n  }\n];"
            },
