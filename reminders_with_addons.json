        {
            "parameters": {
                "jsCode": "var booking = $input.item.json;\nvar simulatorMap = {1: 'Lounge Bay', 2: 'Middle Bay', 3: 'Window Bay'};\nvar bayName = simulatorMap[booking.simulator_id] || ('Bay ' + booking.simulator_id);\n\n// Intelligent Add-on Detection\nvar addonList = [];\nif (booking.addon_coaching) addonList.push('<li>⛳ <strong>Pro Coaching Session</strong> (Confirmed)</li>');\nif (booking.addon_club_rental) addonList.push('<li>⛳ <strong>Premium Club Rental</strong> (Reserved)</li>');\nvar addonsSection = addonList.length > 0 \n    ? `<div style=\"background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 18px; margin: 0 0 20px;\">\n        <p style=\"margin: 0 0 10px; font-weight: bold; color: #166534; font-size: 14px;\">📦 YOUR ADD-ONS</p>\n        <ul style=\"margin: 0; padding-left: 18px; color: #4b5563; line-height: 1.6; font-size: 14px;\">${addonList.join('')}</ul>\n       </div>` \n    : '';\n\nvar html = `\n<div style=\"font-family: 'Segoe UI', Arial, sans-serif; color: #1f2937; max-width: 580px; margin: 0 auto; background: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;\">\n    <div style=\"background: linear-gradient(135deg, #166534 0%, #22c55e 100%); padding: 28px; text-align: center;\">\n        <h1 style=\"color: white; margin: 0; font-size: 26px;\">⛳ See You Tomorrow!</h1>\n        <p style=\"color: rgba(255,255,255,0.9); margin: 8px 0 0; font-size: 15px;\">Your tee time is confirmed</p>\n    </div>\n    <div style=\"padding: 25px;\">\n        <p style=\"font-size: 16px; margin: 0 0 15px;\">Hi <strong>${booking.guest_name}</strong>,</p>\n        <p style=\"color: #6b7280; line-height: 1.6; margin: 0 0 20px;\">We're excited to have you at The Mulligan! Here's everything you need to know.</p>\n        \n        <div style=\"background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); border: 2px solid #22c55e; border-radius: 12px; padding: 20px; margin: 0 0 25px; text-align: center;\">\n            <p style=\"margin: 0 0 8px; font-size: 22px; font-weight: bold; color: #166534;\">📅 ${booking.booking_date}</p>\n            <p style=\"margin: 0 0 8px; font-size: 20px; color: #166534;\">🕓 ${booking.start_time}</p>\n            <p style=\"margin: 0; font-size: 15px; color: #6b7280;\">📍 ${bayName}</p>\n        </div>\n\n        ${addonsSection}\n\n        <div style=\"background: #fffbeb; border: 1px solid #f59e0b; border-radius: 12px; padding: 20px; margin: 0 0 20px;\">\n            <p style=\"margin: 0 0 15px; font-weight: bold; color: #b45309; font-size: 15px; text-align: center;\">📋 THE MULLIGAN'S BASICS</p>\n            <ul style=\"margin: 0; padding-left: 20px; color: #4b5563; font-size: 14px; line-height: 1.9;\">\n                <li><strong>Arrive 15 mins early</strong></li>\n                <li><strong>Golf glove is compulsory</strong></li>\n                <li><strong>No spiked shoes</strong> - flat soles only</li>\n                <li><strong>Clean balls only</strong> - no Sharpie marks</li>\n                <li><strong>No smoking/vaping</strong> indoors</li>\n            </ul>\n            <p style=\"margin: 15px 0 0; padding-top: 12px; border-top: 1px solid #fcd34d; font-size: 12px; color: #92400e; text-align: center;\">📍 38A Chopin St, Vanderbijlpark</p>\n        </div>\n\n        <div style=\"text-align: center;\">\n            <a href=\"https://maps.google.com/?q=38A+Chopin+St+Vanderbijlpark\" style=\"display: inline-block; background: #166534; color: white; padding: 12px 28px; border-radius: 8px; text-decoration: none; font-weight: bold;\">📍 Get Directions</a>\n        </div>\n    </div>\n</div>`;\n\n// No more 'json' nesting\nreturn {\n  from: \"The Mulligan <bookings@themulligan.org>\",\n  to: booking.guest_email,\n  subject: \"⛳ See You Tomorrow! | Your Booking Reminder\",\n  html: html\n};"
            },
