        {
            "parameters": {
                "jsCode": "var items = Array.isArray($input.all()) ? $input.all() : [$input.item];\nvar now = new Date();\n\n// 24h = 23 to 25 hours from now\nvar min24h = new Date(now.getTime() + 23 * 60 * 60000);\nvar max24h = new Date(now.getTime() + 25 * 60 * 60000);\n\nreturn items.filter(item => {\n  var start = new Date(item.json.slot_start);\n  return start >= min24h && start <= max24h;\n});"
