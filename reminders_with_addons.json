        {
            "parameters": {
                "jsCode": "var booking = $input.item.json;\nvar simulatorMap = {1: 'Lounge Bay', 2: 'Middle Bay', 3: 'Window Bay'};\nvar bayName = simulatorMap[booking.simulator_id] || ('Bay ' + booking.simulator_id);\n\n// Intelligent Add-on Detection\nvar addonList = [];\nif (booking.addon_coaching) addonList.push('<li>⛳ <strong>Pro Coaching Session</strong> (Confirmed)</li>');\nif (booking.addon_club_rental) addonList.push('<li>⛳ <strong>Premium Club Rental</strong> (Reserved)</li>');\nvar addonsSection = addonList.length > 0 \n    ? `<div style=\"background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 18px; margin: 0 0 20px;\">\n        <p style=\"margin: 0 0 10px; font-weight: bold; color: #166534; font-size: 14px;\">📦 YOUR ADD-ONS</p>\n        <ul style=\"margin: 0; padding-left: 18px; color: #4b5563; line-height: 1.6; font-size: 14px;\">${addonList.join('')}</ul>\n       </div>` \n    : '';\n\nvar html = `\n<div style=\"font-family: 'Segoe UI', Arial, sans-serif; color: #1f2937; max-width: 520px; margin: 0 auto; background: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;\">\n    <div style=\"background: linear-gradient(135deg, #166534 0%, #22c55e 100%); padding: 25px; text-align: center;\">\n        <h1 style=\"color: white; margin: 0; font-size: 24px;\">⛳ You're Up Next!</h1>\n        <p style=\"color: rgba(255,255,255,0.9); margin: 8px 0 0; font-size: 15px;\">Your session starts in 1 hour</p>\n    </div>\n    <div style=\"padding: 25px;\">\n        <p style=\"font-size: 16px; margin: 0 0 15px;\">Hi <strong>${booking.guest_name}</strong>,</p>\n        <p style=\"color: #6b7280; line-height: 1.6; margin: 0 0 20px;\">Get ready to tee off! We're prepping your bay and can't wait to see you.</p>\n        \n        <div style=\"background: #f8fafc; border-left: 4px solid #166534; padding: 18px; border-radius: 8px; margin: 0 0 20px;\">\n            <p style=\"margin: 0 0 4px; font-size: 14px; color: #166534; font-weight: 600;\">START TIME</p>\n            <p style=\"margin: 0 0 8px; font-size: 26px; font-weight: bold; color: #111827;\">🕓 ${booking.start_time}</p>\n            <p style=\"margin: 0; font-size: 16px; color: #6b7280;\">📍 ${bayName}</p>\n        </div>\n\n        ${addonsSection}\n\n        <div style=\"background: #fffbeb; border: 1px solid #fcd34d; border-radius: 10px; padding: 18px; margin: 0 0 20px;\">\n            <p style=\"margin: 0 0 12px; font-weight: bold; color: #b45309; font-size: 14px;\">📋 QUICK HOUSE RULES</p>\n            <ul style=\"margin: 0; padding-left: 18px; color: #6b7280; line-height: 1.9; font-size: 14px;\">\n                <li><strong>Arrive 15 mins early</strong> for check-in</li>\n                <li><strong>Golf Glove</strong> is compulsory</li>\n                <li><strong>Flat-soled shoes only</strong></li>\n                <li>No Sharpie-marked balls</li>\n            </ul>\n        </div>\n\n        <p style=\"color: #dc2626; font-weight: bold; font-size: 14px; text-align: center;\">⚠️ Running late? Please call us!</p>\n    </div>\n</div>`;\n\n// No more 'json' nesting\nreturn {\n  from: \"The Mulligan <bookings@themulligan.org>\",\n  to: booking.guest_email,\n  subject: \"⛳ Tee Time in 1 Hour! | The Mulligan\",\n  html: html\n};"
            },
