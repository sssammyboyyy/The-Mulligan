        {
            "parameters": {
                "jsCode": "var items = Array.isArray($input.all()) ? $input.all() : [$input.item];\nvar now = new Date();\n\n// 1h = 55 to 85 mins from now\nvar min1h = new Date(now.getTime() + 55 * 60000);\nvar max1h = new Date(now.getTime() + 85 * 60000);\n\nreturn items.filter(item => {\n  var start = new Date(item.json.slot_start);\n  return start >= min1h && start <= max1h;\n});"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
